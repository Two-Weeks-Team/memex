{
  "//": "Memex · Cursor integration. `memex install cursor` writes this to .cursor/mcp.json (project) or ~/.cursor/mcp.json (global). Cursor uses stdio command/args. For the warm HTTP engine, replace command/args with: \"url\": \"http://localhost:8765/mcp\".",
  "mcpServers": {
    "memex": {
      "command": "memex",
      "args": ["mcp"]
    }
  }
}
